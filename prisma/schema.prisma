// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @default(autoincrement()) @id
  name String @db.VarChar(200)
  lastname String @db.VarChar(300)
  username String @db.VarChar(100)
  password String @db.Text
  hash String? @db.Text() //npx prisma migrate dev --name init
  role String @default("USER") @db.VarChar(10)
  created_at DateTime @default(now())
  tasks Task[] //Un usuario puede tener muchas tareas
  logs Logs[] 
}

model Task {
  id Int @default(autoincrement()) @id
  name String @db.VarChar(150)
  description String @db.VarChar(200)
  priority Boolean
  created_at DateTime @default(now())
  user_id Int
  user User @relation(fields: [user_id], references: [id]) //Una tarea pertenece a un usuario
}

model Logs{
  id Int @default(autoincrement()) @id
  statusCode Int
  timeStamp DateTime
  path String @db.Text()
  error String @db.Text()
  errorCode String @db.Text()
  event String? @db.Text()
  severity String @default("INFO") @db.VarChar(20)
  session_id Int?
  user User? @relation(fields: [session_id], references : [id])
}
